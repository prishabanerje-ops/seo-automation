# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Security
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_string_minimum_32_chars

# Screaming Frog
# macOS: /Applications/Screaming\ Frog\ SEO\ Spider.app/Contents/MacOS/ScreamingFrogSEOSpider
# Linux: ~/.local/bin/ScreamingFrogSEOSpider
SF_BINARY_PATH=~/.local/bin/ScreamingFrogSEOSpider
SF_LICENSE_KEY=

# Google OAuth2 (for GSC + GA4 + Sheets)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Enable: Search Console API, Google Analytics Data API v1, Google Sheets API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gsc/callback

# Notifications (optional)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourplatform.com

# Note: Anthropic API key, PSI API key, Linear API key
# are stored in the database via the Settings page — not here.
